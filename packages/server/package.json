{
  "name": "@emu/server",
  "version": "0.1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "nodemon --watch src --watch ../core/src --watch ../../apps --ext ts,json --ignore \"**/test/**\" --exec \"tsx src/main.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emu/core": "link:../core",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fflate": "0.8.3",
    "pdfmake": "^0.3.11"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pdfmake": "^0.3.3",
    "nodemon": "^3.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
